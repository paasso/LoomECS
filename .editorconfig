root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{csproj,props,targets,json,yml,yaml,md}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.cs]
# Language
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = false

# Diagnostics (IDE / compiler)
# .NET 10 requires GenerateDocumentationFile for this analyzer in command-line builds.
# Keep redundant-usings cleanup available through IDE tooling without blocking CI.
dotnet_diagnostic.IDE0005.severity = none
dotnet_diagnostic.CS1591.severity = none
# Relation Target fields are written via reflection (RelationAccess).
dotnet_diagnostic.CS0649.severity = suggestion

# Nullable / correctness
dotnet_diagnostic.CS8600.severity = warning
dotnet_diagnostic.CS8602.severity = warning
dotnet_diagnostic.CS8603.severity = warning
dotnet_diagnostic.CS8604.severity = warning
dotnet_diagnostic.CS8618.severity = warning
